# Copy once:  cp scripts/gcp_env.example scripts/gcp_env
# Then edit if your names differ. scripts/gcp_env is gitignored.

export GCP_PROJECT=fluxtrader
export GCP_ZONE=me-central1-b
# GCP_REGION is derived from the zone automatically (me-central1-b -> me-central1)

# Always-on VM (collect + UI + inference) — leave running 24/7
export GCP_ALWAYS_ON=fluxtrader-1

# Temporary train VM — created + self-deleted by ./scripts/gcp_train.sh
export GCP_TRAIN_INSTANCE=fluxtrader-train
# Training is CPU-bound, not memory-bound (lazy windows keep feature RAM ~tens of MB).
# 4 vCPU speeds up the LSTM far more than extra RAM. e2-standard-4 is 4 vCPU / 16GB.
# For 4 vCPU with less RAM (cost), use e2-custom-4-4096 (4 vCPU / 4GB).
export GCP_TRAIN_MACHINE=e2-standard-4   # 4 vCPU / 16GB

# Folder names under the VM user's $HOME (do not use ~/ or Mac paths)
export REMOTE_REPO_NAME=trading_agent

# --- V2 pipeline: artifacts via GCS bucket, code via git ---------------------
# Single-region bucket, SAME region as the VMs (create once, see gcp_train.sh -h).
export GCS_BUCKET=gs://fluxtrader-train-artifacts
# Reproducible code source. HTTPS so the VM can clone without your SSH key.
# PRIVATE repo: use  https://<PAT>@github.com/VadimMalykh/trading-agent.git
export GIT_REMOTE=https://github.com/VadimMalykh/trading-agent.git
export GIT_REF=main                       # branch or commit SHA to train + serve

# Debug only: 1 = keep train VM alive after the job (never auto delete/stop)
export KEEP_VM=0

# Training defaults (override on the command line of gcp_train.sh if you want)
export TRAIN_EPOCHS=60
export TRAIN_SEQ_LEN=128
export TRAIN_DEVICE=cpu
# M2 Phase 1+2 defaults
export TRAIN_HORIZONS=5,30,60
export TRAIN_PRIMARY=30
# 6 pairs: 3 majors + DOGE/WLD/HYPE (all have full ~180d candles per 2026-07-24 audit).
export TRAIN_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,DOGEUSDT,WLDUSDT,HYPEUSDT
