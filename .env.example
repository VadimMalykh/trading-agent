# Database
DATABASE_URL=postgresql://fluxtrader:secret@postgres:5432/fluxtrader

# Binance (only needed for real/manual/auto trading — not for market data or sim signals)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Trading Mode: simulation, signal, manual, auto
TRADING_MODE=simulation

# ML inference (Phase I light)
ML_INFERENCE_URL=http://ml_inference:8001
ML_GATE_THRESHOLD=0.40
PRIMARY_HORIZON=30
HORIZONS_MINUTES=5,30,60
SEQ_LEN=64
MODEL_PATH=/models/m2_multi.pt

# Risk
MAX_POSITIONS=3
MAX_POSITION_PCT=0.10
STOP_LOSS_PCT=0.02
TAKE_PROFIT_RATIO=2.0
LEVERAGE=5

# Whitelist pairs (comma-separated)
WHITELIST_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT
